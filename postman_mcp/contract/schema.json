    "ExtractionMethod": {
      "description": "The evidence class \u2014 determines the confidence cap of a fact.\n\nOnly ``AI_INFERRED`` may be asserted by an LLM submission on its own authority;\nevery higher class is *earned* through MCP verification (agreement/audit), never\nsubmitted directly by a non-witness producer. Unknown/malformed values are\ntreated as ``AI_INFERRED`` by the scorer \u2014 never as a higher class.",
      "enum": [
        "openapi_verified",
        "ast_verified",
        "framework_verified",
        "multi_source_inferred",
        "ai_inferred",
        "weak_inference"
      ],
      "title": "ExtractionMethod",
      "type": "string"
    },
